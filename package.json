{
  "name": "dual-channel-colocalization-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "main.cjs",
  "description": "Probabilistic Colocalization Estimator",
  "author": "Kai Hong Ooi, mansonooi@yahoo.com",
  
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^25.0.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "^2.0.5",
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.ooi.pce",
    "productName": "Colocalization Workbench",
    
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*", 
      "main.cjs",
      "preload.cjs",
      "package.json"
    ],
    
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": ["**/*"]
      }
    ],
    
    "mac": {
      "category": "public.app-category.education",
      "target": "dmg"
    },
    "win": {
      "target": "portable"
    }
  }
}
